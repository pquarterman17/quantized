{
  "name": "quantized-frontend",
  "private": true,
  "version": "0.10.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test --config=e2e/playwright.config.ts"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "d3-contour": "^4.0.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "uplot": "^1.6.31",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/d3-contour": "^3.0.6",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.7.0",
    "jsdom": "^29.1.1",
    "typescript": "~5.9.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20"
  },
  "optionalDependencies": {
    "canvas": "^3.2.3"
  }
