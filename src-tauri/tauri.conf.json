{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Quantized",
  "version": "0.2.5",
  "identifier": "app.quantized.desktop",
  "build": {
    "frontendDist": "../src/quantized/web"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Quantized",
        "width": 1440,
        "height": 920,
        "minWidth": 960,
        "minHeight": 600,
        "url": "loading.html",
        "backgroundColor": "#15131b"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/pquarterman17/quantized/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDYyRDFEMEIyQjAzRUNFNwpSV1RuN0FNckN4MHRCczhsRDNCTFhkazU0UmJhYlBWL3JacUpSd0F0SGpOQ1IyK1AzQ29zeEJvZwo="
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
